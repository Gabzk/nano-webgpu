{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"types": ["vitest/globals", "vite/client", "@webgpu/types"],
		"lib": ["ESNext", "DOM", "DOM.Iterable"],
		"paths": {
			"nano-webgpu": ["./src/index.ts"]
		},
		"declaration": true,
		"declarationDir": "./dist",
		"outDir": "./dist",
		"rootDir": "./src",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"forceConsistentCasingInFileNames": true
	},
	"include": ["src"],
	"exclude": ["node_modules", "dist", "test", "demo"]
}
